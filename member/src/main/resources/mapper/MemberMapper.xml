<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!-- namespace = Mapper 인터페이스 전체 경로 (정확히 일치해야 함!) -->
<mapper namespace="com.example.member.mapper.MemberMapper">

    <select id="findAll" resultType="Member">
        select id, name, email
        from member
        order by id desc
    </select>

    <select id="findById" resultType="Member">
        select id, name, email
        from member
        where id = #{id}
    </select>

    <!--
        select id, name, email
        from member
        where name like '%길동%';
    -->
    <select id="findByNameContaining" resultType="Member">
        select id, name, email
        from member
        where name like concat('%', #{keyword}, '%')
    </select>


    <select id="findByEmail" resultType="Member">
        select id, name, email
        from member
        where email = #{email}
    </select>


    <update id="updateMember" parameterType="Member">
        update member
        set name = #{name},
        email = #{email}
        where id = #{id};
    </update>

    <!-- useGeneratedKeys: AUTO_INCREMENT 키 자동 반환 -->
    <!-- INSERT INTO member (name, email) VALUES ('홍길동', 'hong@example.com');-->
    <insert id="insertMember" parameterType="Member"
            useGeneratedKeys="true" keyProperty="id">
        insert into member(name, email)
        values(#{name}, #{email})

    </insert>

    <delete id="deleteMember">
        delete from member
        where id = #{id}
    </delete>




</mapper>